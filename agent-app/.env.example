# === LLM CONFIGURATION ===
# Change LLM_PROVIDER to switch ALL agents at once
# Supported: anthropic, openai, google

LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514    # optional: override default model

# === API KEYS ===
# Only the key for your chosen provider needs to be set

ANTHROPIC_API_KEY=your-anthropic-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# GOOGLE_API_KEY=your-google-api-key-here
# SARVAM_API_KEY=your-sarvam-api-key-here

# === LANGSMITH (Observability — zero code changes needed) ===
# See full traces of every agent: input, output, timing, tokens
# Dashboard: https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=ai-research-team
